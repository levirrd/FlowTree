<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FlowTree.Avalonia.CreateProjectWindow"
        Title="Create Project"
        Width="420"
        Height="420"
        MinWidth="360"
        MinHeight="360"
        WindowStartupLocation="CenterOwner">

    <Grid Background="#1E1E1E">

        <Border Padding="24"
                MaxWidth="460"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                Margin="16"
                Background="#252525"
                CornerRadius="12">

            <Grid RowDefinitions="Auto,*,Auto"
                  RowSpacing="16">

                <TextBlock Grid.Row="0"
                           Text="Create New Project"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"/>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto">

                    <StackPanel Spacing="14">

                        <TextBlock Text="Title"
                                   Foreground="White"/>
                        <TextBox x:Name="ProjectNameBox"
                                 PlaceholderText="Enter project title"
                                 HorizontalAlignment="Stretch"/>

                        <TextBlock Text="Subtitle"
                                   Foreground="White"/>
                        <TextBox x:Name="ProjectSubtitleBox"
                                 PlaceholderText="Enter project subtitle"
                                 HorizontalAlignment="Stretch"/>

                        <TextBlock Text="Description"
                                   Foreground="White"/>
                        <TextBox x:Name="ProjectDescriptionBox"
                                 PlaceholderText="Enter project description"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="90"
                                 HorizontalAlignment="Stretch"/>

                    </StackPanel>
                </ScrollViewer>

                <Grid Grid.Row="2"
                      ColumnDefinitions="*,*"
                      ColumnSpacing="12">

                    <Button Grid.Column="0"
                            Content="Cancel"
                            Click="Cancel_Click"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Background="#444444"
                            Foreground="White"
                            BorderBrush="#555555"
                            CornerRadius="8"
                            Padding="12"/>

                    <Button Grid.Column="1"
                            Content="Create"
                            Click="Create_Click"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Background="#333333"
                            Foreground="White"
                            BorderBrush="#444444"
                            CornerRadius="8"
                            Padding="12"/>

                </Grid>

            </Grid>
        </Border>
    </Grid>
</Window>