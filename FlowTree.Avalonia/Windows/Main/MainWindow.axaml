<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="800"
        d:DesignHeight="450"
        x:Class="FlowTree.Avalonia.MainWindow"
        Title="FlowTree"
        Width="1000"
        Height="650"
        MinWidth="700"
        MinHeight="450">

    <Grid Background="#1E1E1E">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" MinWidth="180" MaxWidth="300"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!-- Left sidebar -->
        <Border Grid.Column="0"
                Background="#2B2B2B"
                Padding="12">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- App title -->
                <TextBlock Grid.Row="0"
                           Text="FlowTree"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="LimeGreen"
                           Margin="8,8,0,20"/>

                <!-- Projects area -->
                <Grid Grid.Row="1"
                      RowDefinitions="Auto,*"
                      RowSpacing="12">

                    <!-- Sidebar header -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Projects"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>

                        <Button Grid.Column="1" 
                                Content="+"
                                Click="NewProject_Click"
                                Background="#3A3A3A" 
                                Foreground="LimeGreen" 
                                BorderBrush="#4A4A4A" 
                                CornerRadius="8" 
                                FontSize="18" 
                                FontWeight="Bold" />
                    </Grid>

                    <!-- Project list -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="ProjectsPanel"
                                    Spacing="8"/>
                    </ScrollViewer>
                </Grid>

                <!-- Bottom profile/settings area -->
                <StackPanel Grid.Row="2"
                            Spacing="12"
                            Margin="0,16,0,0">

                    <!-- Account card -->
                    <Border Background="#202020"
                            BorderBrush="#3A3A3A"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12">

                        <StackPanel Spacing="10">

                            <!-- User info -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="1"
                                            Margin="10,0,0,0"
                                            VerticalAlignment="Center">

                                    <TextBlock x:Name="AccountUsernameText"
                                               Text="Not logged in"
                                               Foreground="White"
                                               FontWeight="SemiBold"/>

                                    <TextBlock x:Name="AccountDatabaseText"
                                               Text="Local account"
                                               Foreground="#AAAAAA"
                                               FontSize="12"/>

                                    <TextBlock x:Name="AccountStatusText"
                                               Text=""
                                               Foreground="LimeGreen"
                                               FontSize="12"
                                               IsVisible="False"/>
                                </StackPanel>
                            </Grid>

                            <Button x:Name="LoginButton"
                                    Content="Login"
                                    HorizontalAlignment="Stretch"
                                    VerticalContentAlignment="Center"
                                    HorizontalContentAlignment="Center"
                                    Background="#333333"
                                    Foreground="White"
                                    BorderBrush="#444444"
                                    CornerRadius="8"
                                    Padding="10"
                                    Click="Login_Click"/>

                            <Button x:Name="LogoutButton"
                                    Content="Logout"
                                    HorizontalAlignment="Stretch"
                                    VerticalContentAlignment="Center"
                                    HorizontalContentAlignment="Center"
                                    Background="#4A2222"
                                    Foreground="White"
                                    BorderBrush="#663333"
                                    CornerRadius="8"
                                    Padding="10"
                                    Click="Logout_Click"
                                    IsVisible="False"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

       <!-- Main content, entire right side -->
<Border Grid.Column="1"
        Background="#1E1E1E"
        Padding="24">

    <Grid RowDefinitions="Auto,*"
          RowSpacing="20">

        <!-- Top bar -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Spacing="4">
                <TextBlock x:Name="SelectedProjectTitleText"
                           Text="Main project area"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="White"/>

                <TextBlock x:Name="SelectedProjectSubtitleText"
                           Text="Select a project from the sidebar or create a new one."
                           Foreground="#AAAAAA"/>
            </StackPanel>

            <Button x:Name="NewCardContainerButton"
                    Grid.Column="1"
                    Content="+ Card Container"
                    Click="NewCardContainer_Click"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Background="#333333"
                    Foreground="White"
                    BorderBrush="#444444"
                    CornerRadius="8"
                    Padding="12,8"
                    IsVisible="False"/>
        </Grid>

        <!-- Card containers area -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto">
            <StackPanel x:Name="CardContainersPanel"
                        Spacing="12"/>
        </ScrollViewer>

    </Grid>
</Border>
    </Grid>
</Window>